<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutOpcoes"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <RadioGroup
        android:id="@+id/rgOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbRemoveList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remover desta lista" />

        <RadioButton
            android:id="@+id/rbReturnNormal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar ao estado normal" />

        <RadioButton
            android:id="@+id/rbDeletePermanent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Excluir completamente" />
    </RadioGroup>

    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Confirmar" />
</LinearLayout>
