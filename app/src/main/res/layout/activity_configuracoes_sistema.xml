<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configurações do Sistema"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="16dp" />

        <!-- 1. DADOS E SINCRONIZAÇÃO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dados e Sincronização"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/switchOnline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Modo online" />

                <Button
                    android:id="@+id/btnSincronizar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sincronizar base agora" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. ALERTAS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alertas e Notificações"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/switchValidade"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alertar validade próxima" />

                <Switch
                    android:id="@+id/switchAprovacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alertar aprovação pendente" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. CADASTRO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cadastro de Produtos"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/switchFotoObrigatoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Foto obrigatória no cadastro" />

                <Switch
                    android:id="@+id/switchValidadeObrigatoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Validade obrigatória" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 4. FLUXO COMERCIAL -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fluxo Comercial"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Switch
                    android:id="@+id/switchBloquearSemAprovacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bloquear uso sem aprovação" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 5. SISTEMA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistema"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnLimparCache"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Limpar cache" />

                <Button
                    android:id="@+id/btnRestaurar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Restaurar padrão" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
