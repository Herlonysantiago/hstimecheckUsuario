<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/md_theme_outlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/txtDescricao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descrição do Produto"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold"/>

        <!-- CÓDIGO -->
        <TextView
            android:id="@+id/txtCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Código: 00000000"
            android:paddingTop="4dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"/>

        <!-- PREÇO ATUAL -->
        <TextView
            android:id="@+id/txtPrecoAtual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preço atual: R$ 0,00"
            android:paddingTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"/>

        <!-- PREÇO SUGERIDO -->
        <TextView
            android:id="@+id/txtPrecoSugerido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sugerido: R$ 0,00"
            android:paddingTop="2dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"/>

        <!-- DIFERENÇA % -->
        <TextView
            android:id="@+id/txtDiferenca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:paddingTop="8dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textStyle="bold"/>

        <!-- BOTÕES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditar"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRejeitar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rejeitar"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAprovar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aprovar"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
