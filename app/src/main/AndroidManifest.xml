<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissão obrigatória -->
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:label="HsTimeCheck"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.HsTimeCheck"
        android:forceDarkAllowed="false">

        <!-- SPLASH REAL -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.HsTimeCheck.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela de Detalhe -->
        <activity android:name="com.hs.solutions.hstimecheck.detail.ProdutoDetalheActivity" />
        <activity android:name="com.hs.solutions.hstimecheck.ui.FullImageActivity" />
        <activity android:name="com.hs.solutions.hstimecheck.aprovacao.AprovacaoComercialActivity"/>
        <activity android:name="com.hs.solutions.hstimecheck.ui.PainelOperacionalActivity"/>
        <activity android:name="com.hs.solutions.hstimecheck.ui.TelaListaFiltradaActivity"/>
        <!-- Scanner -->
        <activity
            android:name="com.hs.solutions.hstimecheck.scanner.ScannerActivity"
            android:exported="false" />

        <!-- Tela Principal -->
        <activity
            android:name="com.hs.solutions.hstimecheck.ui.TelaPrincipalActivity"
            android:exported="false" />

        <activity
            android:name=".cadastro.CadastroProdutoActivity"
            android:exported="false" />

    </application>


</manifest>
